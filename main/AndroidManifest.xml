<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.android.example.sms_simulator">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_messages"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_messages_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SMSSimulator"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SMSSimulator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver android:name=".OtpReceiverManifest"
            android:exported="true"
            android:enabled="true"

            tools:ignore="WrongManifestParent">
            <intent-filter>
                <action android:name="com.android.example.sms_simulator.RECEIVE_CODE" />
            </intent-filter>
        </receiver>
    </application>

</manifest>